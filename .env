# ─── Database ────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:Achraf@2026@db.yfszydzplmoesmejyrsl.supabase.co:5432/postgres"

# ─── Authentication ───────────────────────────────────────────────────────────
# Long, random string used to sign JWT tokens. Never commit a real value.
JWT_SECRET="replace_with_a_long_random_secret"

# ─── Shelly Cloud ─────────────────────────────────────────────────────────────
# These keys must NEVER appear in the frontend or any client-side bundle.
# The backend server is the only process that reads them.
SHELLY_AUTH_KEY="MmVkMWVidWlk2CAB39DBD5697035A61BC935AA12DF1D78A1196C07428B5B5AC662F1FCFC040C0B26D4DFC368EEB6"
SHELLY_SERVER_URL="shelly-165-eu.shelly.cloud"

# One Shelly device ID per chair.
# Found in the Shelly Cloud device list (Settings → Device info → Device ID).
SHELLY_DEVICE_F1="f1b457"
SHELLY_DEVICE_F2="f1b3d3"
SHELLY_DEVICE_F3="7c87cebaa2ca"
SHELLY_DEVICE_F4="7c87ceb512a6"
SHELLY_DEVICE_F5="7c87ceb4811e"

# ─── App configuration ────────────────────────────────────────────────────────
# IANA timezone for session timestamps and shift reporting.
APP_TIMEZONE=Africa/Casablanca

# Milliseconds between Shelly Cloud polls (1000 = 1 request per second).
SYNC_INTERVAL_MS=1000

# ─── Frontend (NEXT_PUBLIC_ prefix = safe to expose in browser bundle) ────────
# URL of the backend REST API (used by server-side Next.js calls and SSR).
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL of the Socket.IO server (used by the browser for real-time updates).
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
