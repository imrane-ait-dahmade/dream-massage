PORT=4000
NODE_ENV=development
APP_TIMEZONE=Africa/Casablanca
SYNC_INTERVAL_MS=1000
FRONTEND_ORIGIN=http://localhost:3000

# ── Local PostgreSQL ───────────────────────────────────────────────────────────
# Use this during development. Create the database first (see docs/LOCAL_DATABASE_SETUP.md).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dream_massage?schema=public"

# ── Supabase (production) ──────────────────────────────────────────────────────
# Uncomment and set DATABASE_URL to this when deploying to production.
# SUPABASE_DATABASE_URL="postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-YOURREGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# SUPABASE_DIRECT_URL="postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-YOURREGION.pooler.supabase.com:5432/postgres"

# ── Simulation (development/testing only) ─────────────────────────────────────
# SIMULATION_ENABLED: generates fake power readings for chairs every tick.
# SIMULATION_FAST_MODE: collapses startConfirmSeconds→5s and stopConfirmSeconds→10s
# so the state machine cycles visibly fast during demos. Never use in production.
SIMULATION_ENABLED=true
SIMULATION_FAST_MODE=true

# How often to call Shelly Cloud when simulation is off (ms).
# Dashboard WebSocket still broadcasts every SYNC_INTERVAL_MS.
# Shelly Cloud rate-limits at ~1 req/sec; 5000 is a safe default.
SHELLY_POLL_INTERVAL_MS=5000
