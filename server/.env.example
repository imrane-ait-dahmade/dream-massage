PORT=4001
NODE_ENV=development
APP_TIMEZONE=Africa/Casablanca
SYNC_INTERVAL_MS=1000

DATABASE_URL="postgresql://user:password@localhost:5432/dream_massage?schema=public"
# Neon / production: pooled URL for app runtime (PrismaClient, scripts).
# DATABASE_URL="postgresql://...@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct URL for Prisma CLI migrations only (no -pooler host):
# DIRECT_URL="postgresql://...@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change_me_strong_secret"
JWT_EXPIRES_IN="1095d"
COOKIE_NAME="dream_massage_token"

# Local dev (frontend and backend on the same machine / same LAN):
COOKIE_SECURE=false
COOKIE_SAME_SITE="lax"
FRONTEND_ORIGIN=http://localhost:3000

# Production — frontend on Vercel (HTTPS) + backend on a different domain (HTTPS):
# Safari/iOS blocks cross-site cookies unless SameSite=none AND Secure=true.
# The app now uses a localStorage Bearer token as fallback so login works on all browsers.
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
# FRONTEND_ORIGIN=https://dreamcare-gules.vercel.app
#
# TODO: Long-term fix — use a shared parent domain so cookies are first-party:
#   Frontend:  https://app.dreamcare.ma
#   Backend:   https://api.dreamcare.ma
#   Then: COOKIE_SAME_SITE=lax, COOKIE_SECURE=true, no need for Bearer fallback.

# ─── Simulation ───────────────────────────────────────────────────────────────
SIMULATION_ENABLED=false
SIMULATION_FAST_MODE=false

# ─── Seed demo data ───────────────────────────────────────────────────────────
# Demo data must never run in production. Controls whether `npm run prisma:seed`
# also creates "Demo Staff", the example ASSISTANT login, and (with
# SEED_DEMO_SCHEDULE=true) a demo weekly schedule. Ignored entirely when
# NODE_ENV=production — IS_PRODUCTION always wins over this flag.
DEMO_DATA_ENABLED=false

# ─── Shelly Cloud ─────────────────────────────────────────────────────────────
SHELLY_AUTH_KEY="your_shelly_auth_key"
SHELLY_SERVER_URL="https://shelly-xx-eu.shelly.cloud"
SHELLY_DEVICE_F1="device_id_chair_1"
SHELLY_DEVICE_F2="device_id_chair_2"
SHELLY_DEVICE_F3="device_id_chair_3"
SHELLY_DEVICE_F4="device_id_chair_4"
SHELLY_DEVICE_F5="device_id_chair_5"
