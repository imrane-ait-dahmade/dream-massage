# ─── Server port ──────────────────────────────────────────────────────────────
PORT=4001

# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:password@localhost:5432/dream_massage"

# ─── Authentication ───────────────────────────────────────────────────────────
# Long, random string used to sign JWT tokens. Never commit a real value.
# Generate with: openssl rand -hex 32
JWT_SECRET="replace_with_a_long_random_secret_at_least_32_chars"
JWT_EXPIRES_IN="1095d"

# ─── App configuration ────────────────────────────────────────────────────────
# IANA timezone for session timestamps and shift reporting.
APP_TIMEZONE=Africa/Casablanca

# Frontend origin — allowed for CORS.
FRONTEND_ORIGIN=http://localhost:3000

# Milliseconds between Shelly Cloud polls (5000 recommended).
SYNC_INTERVAL_MS=5000

# ─── Simulation (development only) ────────────────────────────────────────────
# Set to true to use the built-in fake-power simulation instead of real Shelly.
SIMULATION_ENABLED=false
SIMULATION_FAST_MODE=false

# ─── Shelly Cloud ─────────────────────────────────────────────────────────────
# These keys must NEVER appear in the frontend or any client-side bundle.
# The backend server is the only process that reads them.
SHELLY_AUTH_KEY=""
SHELLY_SERVER_URL="https://shelly-xx-eu.shelly.cloud"
SHELLY_POLL_INTERVAL_MS=5000

# One Shelly device ID per chair (Settings → Device info → Device ID in Shelly Cloud).
SHELLY_DEVICE_F1=""
SHELLY_DEVICE_F2=""
SHELLY_DEVICE_F3=""
SHELLY_DEVICE_F4=""
SHELLY_DEVICE_F5=""
